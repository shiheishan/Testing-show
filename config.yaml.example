server:
  host: 0.0.0.0
  port: 8080

db:
  path: ./data/nodes.db

check:
  # 部署机器本地每 6 分钟检测一轮节点。
  interval: 6m
  concurrency: 50
  timeout: 5s
  retention: 24h
  # 客户连续点击测速时，冷却期内直接复用最近结果。
  manual_cooldown: 15s
  # TCP 探活只做入口诊断；如果机器上能找到 mihomo，则用真实代理 delay 作为主状态。
  proxy_enabled: true
  proxy_url: https://www.gstatic.com/generate_204
  # 可选：配置多个真实代理测速目标。任意一个目标成功即认为代理可用。
  # proxy_urls:
  #   - https://www.gstatic.com/generate_204
  #   - https://cp.cloudflare.com/generate_204
  #   - https://www.apple.com/library/test/success.html
  # 真实代理测速比 TCP 探活重，单独限流，避免小 VPS 同时压太多节点。
  proxy_concurrency: 10
  # 先跑一次预热请求，再记录第二次测速，降低冷握手对延迟的影响。
  proxy_warmup: true
  # 留空时自动查找 mihomo / clash-meta / clash。
  # mihomo_path: /usr/local/bin/mihomo
  mihomo_start_timeout: 8s

subscription:
  # 订阅链接单独放在根目录 subscriptions.yaml。
  config_path: subscriptions.yaml
  user_agent: ClashVerge
  timeout: 10s
  refresh_interval: 5m
  # 订阅拉取代理，用于访问被墙的订阅链接。
  # proxy: http://127.0.0.1:7890
